generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Source {
  id              String @id @default(uuid())
  name            String
  provider        String @default("r2")
  endpoint        String
  bucket          String
  /// Encrypted with ENCRYPTION_KEY (AES-256-GCM)
  accessKeyId     String @map("access_key_id")
  /// Encrypted with ENCRYPTION_KEY (AES-256-GCM)
  secretAccessKey String @map("secret_access_key")
  createdAt       String @default(dbgenerated("(datetime('now'))")) @map("created_at")

  @@map("sources")
}
