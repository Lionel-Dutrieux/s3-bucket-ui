generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  provider        String   @default("r2")
  endpoint        String
  bucket          String
  /// Encrypted with ENCRYPTION_KEY (AES-256-GCM)
  accessKeyId     String   @map("access_key_id")
  /// Encrypted with ENCRYPTION_KEY (AES-256-GCM)
  secretAccessKey String   @map("secret_access_key")
  /// Write permissions — sources are read-only unless explicitly enabled.
  allowUpload     Boolean  @default(false) @map("allow_upload")
  allowDelete     Boolean  @default(false) @map("allow_delete")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("sources")
}

/// Audit trail of write operations (upload, delete, rename, folder create).
/// Source name is denormalized so history survives a source being removed.
model Operation {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  sourceId   String?  @map("source_id") @db.Uuid
  sourceName String   @map("source_name")
  target     String
  detail     String?
  actor      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([createdAt])
  @@map("operations")
}
