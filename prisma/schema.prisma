generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  provider        String   @default("r2")
  endpoint        String
  bucket          String
  /// Encrypted with ENCRYPTION_KEY (AES-256-GCM)
  accessKeyId     String   @map("access_key_id")
  /// Encrypted with ENCRYPTION_KEY (AES-256-GCM)
  secretAccessKey String   @map("secret_access_key")
  /// When false, no public share links may be minted for this source and any
  /// existing link resolves as a uniform 404 until it's turned back on.
  allowPublicShares Boolean @default(true) @map("allow_public_shares")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  grants    SourcePermission[]
  shares    Share[]
  dropLinks DropLink[]

  @@map("sources")
}

/// Audit trail of write operations (upload, delete, rename, folder create).
/// Source name is denormalized so history survives a source being removed;
/// userId has no FK for the same reason (history survives account deletion).
model Operation {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  sourceId   String?  @map("source_id") @db.Uuid
  sourceName String   @map("source_name")
  target     String
  detail     String?
  actor      String?
  userId     String?  @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([createdAt])
  @@map("operations")
}

// --- better-auth models (managed by better-auth; ids are text, not uuid) ---

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  // admin plugin
  role          String?
  banned        Boolean?
  banReason     String?   @map("ban_reason")
  banExpires    DateTime? @map("ban_expires") @db.Timestamptz(3)
  /// Snapshot of the IdP `groups` claim at the last OIDC sign-in — drives the
  /// name-matching sync into GroupMember (via = "oidc").
  oidcGroups    String[]  @default([]) @map("oidc_groups")
  // two-factor plugin
  twoFactorEnabled Boolean? @default(false) @map("two_factor_enabled")

  sessions     Session[]
  accounts     Account[]
  memberships  GroupMember[]
  grants       SourcePermission[]
  twoFactors   TwoFactor[]
  ssoProviders SsoProvider[]

  @@map("users")
}

/// SSO identity provider registered through the better-auth SSO plugin
/// (@better-auth/sso). One row per IdP; `oidcConfig` holds the plugin's own
/// JSON blob (client id/secret + discovered endpoints). Managed from
/// Admin → Settings — the per-provider groups-claim name lives alongside in the
/// Setting table (key `sso.groupsClaim.<providerId>`), read by provisionUser.
model SsoProvider {
  id             String  @id
  issuer         String
  domain         String
  oidcConfig     String? @map("oidc_config")
  samlConfig     String? @map("saml_config")
  userId         String? @map("user_id")
  providerId     String  @unique @map("provider_id")
  organizationId String? @map("organization_id")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("sso_providers")
}

model TwoFactor {
  id                      String    @id
  userId                  String    @map("user_id")
  secret                  String
  backupCodes             String    @map("backup_codes")
  verified                Boolean   @default(true)
  failedVerificationCount Int       @default(0) @map("failed_verification_count")
  lockedUntil             DateTime? @map("locked_until") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor")
}

model Session {
  id             String   @id
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(3)
  token          String   @unique
  ipAddress      String?  @map("ip_address")
  userAgent     String?   @map("user_agent")
  userId         String   @map("user_id")
  impersonatedBy String?  @map("impersonated_by")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(3)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("verifications")
}

/// App-wide settings, one row per key (e.g. allowPublicSignUp) — managed
/// from Admin → Settings.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("settings")
}

// --- authorization models (ours) ---

/// App-side group. `name` is the key OIDC group claims are matched against
/// (exact match, à la Homarr).
model Group {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  members GroupMember[]
  grants  SourcePermission[]

  @@map("groups")
}

model GroupMember {
  groupId   String   @map("group_id") @db.Uuid
  userId    String   @map("user_id")
  /// "manual" (added by an admin) or "oidc" (added by the claim sync — only
  /// these are removed when the claim no longer lists the group).
  via       String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

/// A grant gives its subject read access to a source; canEdit (upload, rename,
/// new folder) and canDelete add to it. The subject is exactly one of
/// userId/groupId — enforced by a CHECK constraint in the migration SQL.
model SourcePermission {
  id        String   @id @default(uuid()) @db.Uuid
  sourceId  String   @map("source_id") @db.Uuid
  userId    String?  @map("user_id")
  groupId   String?  @map("group_id") @db.Uuid
  canEdit   Boolean  @default(false) @map("can_edit")
  canDelete Boolean  @default(false) @map("can_delete")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group  Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([sourceId, userId])
  @@unique([sourceId, groupId])
  @@index([userId])
  @@index([groupId])
  @@map("source_permissions")
}

/// Public share link — the app-minted token (the row id) is the capability:
/// anyone holding the URL passes, and expiry/revocation/password on the row
/// gate it. Deleting a source cascades and kills its links; createdById has
/// no FK so links survive account deletion (mirrors Operation.userId).
model Share {
  id           String    @id
  sourceId     String    @map("source_id") @db.Uuid
  /// "file" — key is a single object; "prefix" — key is a folder prefix
  /// (ends with "/") and the link exposes every object under it.
  kind         String    @default("file")
  key          String
  createdById  String    @map("created_by_id")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(3)
  passwordHash String?   @map("password_hash")
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(3)
  downloads    Int       @default(0)
  /// Download cap — null means unlimited. Enforced race-free with a conditional
  /// updateMany (downloads < maxDownloads); an exhausted link reads as expired.
  maxDownloads Int?      @map("max_downloads")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([createdById])
  @@map("shares")
}

/// Public reverse-share ("drop") link — the app-minted token (the row id) is
/// the capability: anyone holding the URL may DEPOSIT files into `prefix`
/// without an account, but never see what is already there. Expiry, revocation
/// and an optional password gate it, exactly like Share. `maxFiles` caps how
/// many objects may ever be dropped (enforced race-free with a conditional
/// updateMany, mirroring Share.maxDownloads) and `maxSizeMb` the size of each.
/// Deleting a source cascades and kills its links; createdById has no FK so
/// links survive account deletion (mirrors Operation.userId / Share).
model DropLink {
  id           String    @id
  sourceId     String    @map("source_id") @db.Uuid
  /// Destination prefix — "" is the bucket root, otherwise ends with "/".
  prefix       String
  createdById  String    @map("created_by_id")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(3)
  passwordHash String?   @map("password_hash")
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(3)
  /// Cap on the number of deposits — null means unlimited. Enforced race-free
  /// with a conditional updateMany (uploadsCount < maxFiles).
  maxFiles     Int?      @map("max_files")
  /// Per-file size cap in mebibytes — null means only the global upload ceiling.
  maxSizeMb    Int?      @map("max_size_mb")
  /// Free-text instruction shown to the guest on the deposit page.
  note         String?
  uploadsCount Int       @default(0) @map("uploads_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([createdById])
  @@map("drop_links")
}
