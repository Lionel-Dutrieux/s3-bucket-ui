                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/lib/dal/**", "src/lib/prisma.ts", "src/lib/auth/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ]
}
