# PostgreSQL connection string used by Prisma (runtime client + migrations).
# Local dev: start one with
#   docker run -d --name bucket-ui-db -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=bucket_ui -p 5432:5432 postgres:17-alpine
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bucket_ui

# Key used to encrypt bucket credentials stored in the database (AES-256-GCM).
# Must be exactly 64 hex characters. Generate with: openssl rand -hex 32
# WARNING: changing this key makes previously saved sources unreadable —
# you would need to delete and re-add them.
ENCRYPTION_KEY=
