# PostgreSQL connection string used by Prisma (runtime client + migrations).
# Local dev: start one with
#   docker run -d --name bucket-ui-db -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=bucket_ui -p 5432:5432 postgres:17-alpine
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bucket_ui

# Key used to encrypt bucket credentials stored in the database (AES-256-GCM).
# Must be exactly 64 hex characters. Generate with: openssl rand -hex 32
# WARNING: changing this key makes previously saved sources unreadable —
# you would need to delete and re-add them.
ENCRYPTION_KEY=

# Secret used by better-auth to sign sessions and tokens (at least 32 chars).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL the app is reached at (scheme included) — cookie security and
# OAuth callbacks derive from it.
BETTER_AUTH_URL=http://localhost:3000

# --- Optional: generic OIDC provider (e.g. Pocket ID, Authentik, Keycloak) ---
# Set all three to enable the SSO button on the sign-in page; leave all three
# unset to disable. The callback URL to register with your IdP is:
#   <BETTER_AUTH_URL>/api/auth/oauth2/callback/oidc
#OIDC_DISCOVERY_URL=https://id.example.com/.well-known/openid-configuration
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
# Label shown on the sign-in button (default: SSO).
#OIDC_PROVIDER_LABEL=Pocket ID
# Scopes requested (default: "openid profile email groups").
#OIDC_SCOPES=openid profile email groups
# Claim holding the user's group names (default: "groups"). Groups whose name
# exactly matches an app group are assigned automatically at sign-in.
#OIDC_GROUPS_CLAIM=groups

# --- Optional: SMTP relay — enables "Forgot password?" reset emails ---
# Set SMTP_HOST and SMTP_FROM together (user/password only if the relay
# requires auth).
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=Bucket UI <bucket-ui@example.com>

# --- Optional: local filesystem sources ---
# Comma-separated allowlist of directories that "Local folder" sources may
# expose (e.g. volumes mounted into the container). Unset = the provider is
# hidden from the admin UI and rejected server-side. Each source exposes
# exactly one of these directories, picked from a list in the admin UI.
#LOCAL_FS_ROOTS=/data,/srv/media
