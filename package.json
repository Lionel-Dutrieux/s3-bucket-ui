{
  "name": "s3-bucket-ui",
  "version": "1.0.0",
  "description": "Self-hosted file manager for all your storage — S3, R2, Azure, SFTP and more, behind one Drive-style UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lionel-Dutrieux/s3-bucket-ui.git"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/lib-storage": "^3.1085.0",
    "@aws-sdk/s3-presigned-post": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@azure/storage-blob": "^12.33.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "basic-ftp": "^6.0.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "files-sdk": "^2.1.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "nuqs": "^2.9.0",
    "pg": "^8.13.0",
    "prisma": "^7.8.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "simple-icons": "^16.26.0",
    "sonner": "^2.0.7",
    "ssh2-sftp-client": "^12.1.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "webdav": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "tailwindcss": "^4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
